{
  "name": "front",
  "version": "0.0.78",
  "locale": "es_CL",
  "scripts": {
    "ng": "ng",
    "start": "ng serve --ssl",
    "start:prod": "ng serve --configuration production --ssl",
    "start:dev": "ng serve --configuration development --ssl",
    "start:qa": "ng serve --configuration qa --ssl",
    "build": "ng build --configuration production",
    "watch": "ng build --watch --configuration production",
    "test": "set NODE_OPTIONS=--no-deprecation && ng test",
    "deploy": "set NODE_OPTIONS=--no-deprecation && npm version patch && ng build --configuration production && firebase deploy",
    "lint": "ng lint"
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "^19.2.21",
    "@angular/common": "^19.2.21",
    "@angular/compiler": "^19.2.21",
